# Copy this file to `.env` in the same folder (`cp .env.example .env`) and fill in values.
# `.env` is gitignored — do not commit real keys.
# `--dart-define=SUPABASE_*` still overrides these when set.

SUPABASE_URL=
SUPABASE_ANON_KEY=

# Optional — e.g. adakaro://auth-callback (see mobile/README if present)
# AUTH_REDIRECT_URL=
